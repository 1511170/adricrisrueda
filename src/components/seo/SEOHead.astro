---
/**
 * SEOHead.astro - Meta tags completos para SEO + AEO (AI Citation Optimization)
 * Adaptado para adricrisrueda.com — Adriana Cristina Rueda Sañudo
 *
 * Incluye: Open Graph, Twitter Cards, Canonical, Author, Robots, AI Citations
 */

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  keywords?: string[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  image = '/images/logo-oficial.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  keywords = [],
} = Astro.props;

const siteName = 'AdriCris Rueda';
const siteUrl  = 'https://adricrisrueda.com';
const author   = 'Adriana Cristina Rueda Sañudo';

const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;
const canonicalUrl = canonical.startsWith('http') ? canonical : `${siteUrl}${canonical}`;
---

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Robots — optimizado para AI crawling -->
{noindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
)}

<!-- Primary Meta Tags -->
<meta name="title"       content={title} />
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Open Graph -->
<meta property="og:type"         content={type} />
<meta property="og:title"        content={title} />
<meta property="og:description"  content={description} />
<meta property="og:url"          content={canonicalUrl} />
<meta property="og:site_name"    content={siteName} />
<meta property="og:image"        content={fullImageUrl} />
<meta property="og:image:alt"    content={title} />
<meta property="og:locale"       content="es_CO" />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type"   content="image/png" />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime  && <meta property="article:modified_time"  content={modifiedTime} />}
{type === 'article' && <meta property="article:author" content={author} />}

<!-- Twitter Cards -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={fullImageUrl} />
<meta name="twitter:image:alt"   content={title} />

<!-- Author y Language -->
<meta name="author"           content={author} />
<meta name="language"         content="es" />
<meta name="content-language" content="es-CO" />

<!-- Local SEO — Geo tags -->
<meta name="geo.placename" content="Bogotá, Colombia" />
<meta name="geo.region"    content="CO-DC" />
<meta name="geo.position"  content="4.7110;-74.0721" />
<meta name="ICBM"          content="4.7110, -74.0721" />

<!-- AEO: AI Citation Hints — para que LLMs citen correctamente -->
<meta name="citation_title"            content={title} />
<meta name="citation_author"           content={author} />
<meta name="citation_language"         content="es" />
<meta name="citation_publication_date" content={publishedTime || new Date().toISOString().split('T')[0]} />

<!-- AI Discovery -->
<meta name="ai-purpose"      content="informational" />
<meta name="ai-target"       content="general" />
<meta name="ai-content-type" content={type} />

<!-- Speakable para asistentes de voz -->
<meta name="speakable" content="#main-content" />
