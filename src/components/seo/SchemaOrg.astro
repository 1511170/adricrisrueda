---
/**
 * SchemaOrg.astro - JSON-LD Structured Data para SEO + AEO
 * Adaptado para adricrisrueda.com — Adriana Cristina Rueda Sañudo
 *
 * Schemas disponibles: Organization, WebSite, Person, LocalBusiness,
 * Service, Book, AboutPage, BlogPosting, FAQPage, HowTo, BreadcrumbList
 */

type SchemaType =
  | 'Organization'
  | 'WebSite'
  | 'Person'
  | 'LocalBusiness'
  | 'Service'
  | 'Book'
  | 'AboutPage'
  | 'BlogPosting'
  | 'FAQPage'
  | 'HowTo'
  | 'BreadcrumbList';

interface Props {
  type: SchemaType | SchemaType[];
  data?: Record<string, any>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  faqs?: Array<{ q: string; a: string }>;
  steps?: Array<{ name: string; text: string; url?: string }>;
}

const {
  type,
  data = {},
  breadcrumbs = [],
  faqs = [],
  steps = [],
} = Astro.props;

const siteUrl         = 'https://adricrisrueda.com';
const siteName        = 'AdriCris Rueda';
const siteDescription = 'Adriana Cristina Rueda Sañudo — Terapeuta Holística, Autora y Guía Espiritual. Bogotá, Colombia.';
const siteLogo        = `${siteUrl}/images/logo-oficial.png`;
const authorName      = 'Adriana Cristina Rueda Sañudo';
const authorEmail     = 'adriana@adricrisrueda.com';

const socialProfiles = [
  'https://www.instagram.com/adricrisrueda/',
  'https://www.facebook.com/adricrisespiritual/',
  'https://www.youtube.com/@adricrisespiritual',
  'https://co.linkedin.com/in/adriana-cristina-rueda',
];

const types = Array.isArray(type) ? type : [type];

// — Schema builders —

const organizationSchema = {
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  'name': siteName,
  'alternateName': authorName,
  'url': siteUrl,
  'logo': {
    '@type': 'ImageObject',
    'url': siteLogo,
  },
  'description': siteDescription,
  'email': authorEmail,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': 'Bogotá',
    'addressCountry': 'CO',
  },
  'sameAs': socialProfiles,
  'knowsAbout': [
    'Terapia Holística',
    'Reiki Usui',
    'Activación Pineal',
    'Escritura Terapéutica',
    'Sanación Intuitiva',
    'Crecimiento Espiritual',
  ],
};

const webSiteSchema = {
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  'url': siteUrl,
  'name': siteName,
  'description': siteDescription,
  'publisher': { '@id': `${siteUrl}/#organization` },
  'inLanguage': 'es-CO',
};

const personSchema = {
  '@type': 'Person',
  '@id': `${siteUrl}/#person`,
  'name': authorName,
  'alternateName': siteName,
  'jobTitle': 'Terapeuta Holística & Autora',
  'description': 'Reikista, Pinealista, Canalizadora y Autora. Ex-arquitecta reconvertida en guía espiritual. Creadora de la comunidad "Confío y Creo en Mí".',
  'url': siteUrl,
  'image': `${siteUrl}/images/adriana-perfil.png`,
  'email': authorEmail,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': 'Bogotá',
    'addressCountry': 'CO',
  },
  'knowsAbout': [
    'Terapia Holística',
    'Reiki Usui',
    'Activación Pineal',
    'Método Swami Om Hari',
    'Escritura Terapéutica',
    'Crecimiento Espiritual',
  ],
  'sameAs': socialProfiles,
};

const localBusinessSchema = {
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}/#localbusiness`,
  'name': siteName,
  'image': siteLogo,
  'url': siteUrl,
  'email': authorEmail,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': 'Bogotá',
    'addressRegion': 'Cundinamarca',
    'addressCountry': 'CO',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': '4.7110',
    'longitude': '-74.0721',
  },
  'priceRange': '$$',
  'currenciesAccepted': 'COP',
};

function buildServiceSchema(d: Record<string, any>) {
  return {
    '@type': 'Service',
    'provider': { '@id': `${siteUrl}/#person` },
    'areaServed': d.areaServed || { '@type': 'Place', 'name': 'Bogotá, Colombia' },
    'name': d.name || 'Terapia Holística',
    'description': d.description || 'Servicios de sanación holística: Reiki, Activación Pineal, Escritura Terapéutica.',
    'serviceType': d.serviceType || 'Holistic Therapy',
    'inLanguage': 'es-CO',
    ...(d.url && { 'url': d.url }),
    ...(d.offers && {
      'offers': {
        '@type': 'Offer',
        'availability': 'https://schema.org/InStock',
        ...d.offers,
      },
    }),
  };
}

function buildBookSchema(d: Record<string, any>) {
  return {
    '@type': 'Book',
    'name': d.name || 'Una Voz al paso del Eclipse',
    'author': { '@id': `${siteUrl}/#person` },
    'inLanguage': 'es',
    'genre': d.genre || 'Crecimiento Espiritual',
    'description': d.description || 'Un viaje de autoconocimiento a través de la historia de Natalia. Reflexión sobre el reconocimiento, la lealtad a una misma y el renacimiento.',
    'publisher': { '@id': `${siteUrl}/#organization` },
    ...(d.datePublished && { 'datePublished': d.datePublished }),
    ...(d.isbn && { 'isbn': d.isbn }),
    ...(d.url && { 'url': d.url }),
    ...(d.image && { 'image': d.image.startsWith('http') ? d.image : `${siteUrl}${d.image}` }),
  };
}

const aboutPageSchema = {
  '@type': 'AboutPage',
  'mainEntity': { '@id': `${siteUrl}/#person` },
  'url': `${siteUrl}/sobre-mi`,
  'name': `Sobre Mí — ${authorName}`,
  'description': 'De arquitecta a terapeuta holística. Conoce la historia de Adriana Cristina Rueda Sañudo.',
  'inLanguage': 'es-CO',
};

function buildBlogPostingSchema(d: Record<string, any>) {
  return {
    '@type': 'BlogPosting',
    'headline': d.title || '',
    'description': d.description || d.excerpt || '',
    'author': { '@id': `${siteUrl}/#person` },
    'publisher': { '@id': `${siteUrl}/#organization` },
    'datePublished': d.datePublished || '',
    'dateModified': d.dateModified || d.datePublished || '',
    'mainEntityOfPage': d.url || Astro.url.href,
    'inLanguage': 'es-CO',
    ...(d.image && {
      'image': {
        '@type': 'ImageObject',
        'url': d.image.startsWith('http') ? d.image : `${siteUrl}${d.image}`,
      },
    }),
  };
}

function buildFAQSchema(items: Array<{ q: string; a: string }>) {
  return {
    '@type': 'FAQPage',
    'mainEntity': items.map((faq) => ({
      '@type': 'Question',
      'name': faq.q,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.a,
      },
    })),
  };
}

function buildHowToSchema(items: Array<{ name: string; text: string; url?: string }>, d: Record<string, any>) {
  return {
    '@type': 'HowTo',
    'name': d.howToName || 'Cómo funciona la terapia holística',
    'description': d.howToDescription || 'Guía paso a paso',
    'step': items.map((step, i) => ({
      '@type': 'HowToStep',
      'position': i + 1,
      'name': step.name,
      'text': step.text,
      ...(step.url && { 'url': step.url }),
    })),
  };
}

function buildBreadcrumbSchema(items: Array<{ name: string; url: string }>) {
  return {
    '@type': 'BreadcrumbList',
    'itemListElement': items.map((item, i) => ({
      '@type': 'ListItem',
      'position': i + 1,
      'name': item.name,
      'item': item.url.startsWith('http') ? item.url : `${siteUrl}${item.url}`,
    })),
  };
}

// — Construir el graph final —
const graph: any[] = [];

for (const t of types) {
  switch (t) {
    case 'Organization':
      graph.push(organizationSchema);
      break;
    case 'WebSite':
      graph.push(webSiteSchema);
      break;
    case 'Person':
      graph.push(personSchema);
      break;
    case 'LocalBusiness':
      graph.push(localBusinessSchema);
      break;
    case 'Service':
      graph.push(buildServiceSchema(data));
      break;
    case 'Book':
      graph.push(buildBookSchema(data));
      break;
    case 'AboutPage':
      graph.push(aboutPageSchema);
      break;
    case 'BlogPosting':
      graph.push(buildBlogPostingSchema(data));
      break;
    case 'FAQPage':
      if (faqs.length > 0) graph.push(buildFAQSchema(faqs));
      break;
    case 'HowTo':
      if (steps.length > 0) graph.push(buildHowToSchema(steps, data));
      break;
    case 'BreadcrumbList':
      if (breadcrumbs.length > 0) graph.push(buildBreadcrumbSchema(breadcrumbs));
      break;
  }
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
