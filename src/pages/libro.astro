---
import Layout from '../layouts/Layout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Layout
  title="Una Voz al paso del Eclipse | Adriana Cristina Rueda Sañudo"
  description="Nuevo libro de Adriana Rueda. Un viaje de autoconocimiento a través de la historia de Natalia. Reflexión sobre reconocimiento, lealtad y renacimiento. Feria del Libro de Bogotá, Abril 2026."
  image="/images/portada-libro-2.png"
  keywords={['Una Voz al paso del Eclipse', 'libro Adriana Rueda', 'Feria del Libro Bogotá 2026', 'autora colombiana', 'crecimiento espiritual', 'novela espiritual']}
>
  <SchemaOrg
    slot="head"
    type={['Book']}
    data={{
      name: 'Una Voz al paso del Eclipse',
      genre: 'Crecimiento Espiritual',
      description: 'Un viaje de autoconocimiento a través de la historia de Natalia. Reflexión sobre reconocimiento, lealtad a una misma y renacimiento.',
      datePublished: '2026-04-11',
      image: '/images/portada-libro-2.png',
      url: 'https://adricrisrueda.com/libro',
    }}
  />
  <SchemaOrg
    slot="head"
    type={['BreadcrumbList']}
    breadcrumbs={[
      { name: 'Inicio', url: '/' },
      { name: 'Biblioteca', url: '/libros' },
      { name: 'Una Voz al paso del Eclipse', url: '/libro' },
    ]}
  />
  <!-- Hero Section -->
  <header class="relative min-h-screen flex items-center justify-center pt-24 overflow-hidden" id="inicio">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-secondary/5 rounded-full blur-[100px] dark:bg-secondary/5"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-secondary/10 rounded-full opacity-30 animate-[spin_60s_linear_infinite]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] border border-accent/10 rounded-full opacity-30 animate-[spin_40s_linear_infinite_reverse]"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-12 md:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="order-1 flex justify-center perspective-1000 relative">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-secondary/20 to-accent/20 rounded-full blur-3xl -z-10 opacity-60"></div>
          <div class="relative w-[280px] md:w-[380px] lg:w-[420px] animate-float">
            <img
              alt="Portada del libro Una Voz al paso del Eclipse — historia de autoconocimiento y renacimiento por Adriana Cristina Rueda Sañudo, presentado en la Feria del Libro de Bogotá 2026"
              class="w-full h-auto drop-shadow-2xl shadow-secondary/20 rounded-r-xl rounded-l-sm transform rotate-y-12 hover:rotate-y-0 transition-transform duration-700 ease-out cursor-pointer"
              src="/images/portada-libro-2.png"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
            <div class="absolute -bottom-8 left-0 right-0 h-8 bg-gradient-to-b from-black/10 to-transparent blur-md rounded-[50%] transform scale-x-90"></div>
          </div>
        </div>
        <div class="order-2 text-center lg:text-left space-y-8">
          <div class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-secondary/20 dark:bg-secondary/30 border border-secondary/30 shadow-sm mx-auto lg:mx-0">
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
            <span class="text-primary dark:text-secondary text-xs font-bold tracking-[0.2em] uppercase">Lanzamiento: Feria del Libro de Bogotá 2026</span>
          </div>
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl leading-[1.1] text-primary dark:text-white">
            Una Voz <br/>
            <span class="italic font-light text-4xl md:text-5xl lg:text-6xl text-gray-600 dark:text-gray-300">al paso del Eclipse</span>
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-300 max-w-lg mx-auto lg:mx-0 font-light leading-relaxed tracking-wide">
            La conmovedora historia de Natalia y su viaje hacia el reencuentro consigo misma. Una narrativa sobre la valentía de mirarse de frente y renacer desde la propia sombra.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
            <a class="gold-gradient hover:opacity-90 text-primary px-8 py-4 rounded-full font-display font-medium tracking-wide transition-all shadow-lg shadow-secondary/30 hover:shadow-secondary/50 transform hover:-translate-y-1 flex items-center justify-center gap-2" href="#comprar">
              <span class="material-symbols-outlined">how_to_reg</span>
              PRE-REGISTRARSE
            </a>
            <a class="border border-primary text-primary hover:bg-primary hover:text-white px-8 py-4 rounded-full font-display font-medium tracking-wide transition-all flex items-center justify-center gap-2" href="#comprar">
              <span class="material-symbols-outlined">notifications</span>
              RECIBE NOTIFICACIONES
            </a>
          </div>
          <div class="pt-6 flex items-center justify-center lg:justify-start gap-6 opacity-70">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-secondary text-sm">star</span>
              <span class="material-symbols-outlined text-secondary text-sm">star</span>
              <span class="material-symbols-outlined text-secondary text-sm">star</span>
              <span class="material-symbols-outlined text-secondary text-sm">star</span>
              <span class="material-symbols-outlined text-secondary text-sm">star</span>
            </div>
            <span class="text-xs font-medium uppercase tracking-widest text-gray-500 dark:text-gray-400">Próximo Lanzamiento: Abril 2026</span>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
      <a class="animate-bounce p-2 rounded-full text-primary/50 dark:text-white/50 hover:text-primary dark:hover:text-white transition-colors" href="#sinopsis">
        <span class="material-symbols-outlined text-3xl">keyboard_arrow_down</span>
      </a>
    </div>
  </header>

  <!-- Sinopsis Section -->
  <section class="py-24 md:py-32 bg-white dark:bg-surface-dark relative overflow-hidden" id="sinopsis">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-background-light dark:bg-background-dark/30 -skew-x-12 transform origin-top-right z-0"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
        <div class="lg:w-1/2 space-y-8">
          <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs block mb-2">Sinopsis</span>
          <h2 class="font-display text-4xl md:text-5xl text-primary dark:text-white leading-tight">Una Voz al Paso <span class="italic text-accent">del Eclipse</span></h2>
          <div class="prose dark:prose-invert text-gray-600 dark:text-gray-300 font-light text-lg leading-relaxed space-y-6">
            <p>
              <span class="text-5xl float-left mr-3 mt-[-10px] font-display text-secondary">N</span>atalia, una mujer de cincuenta años que hace tiempo dejó atrás la profesión que la desgastaba, vive sola, en una calma que a veces confunde con plenitud. Durante años ha aprendido a acomodarse a lo que otros esperan de ella, apagando, casi sin notarlo, la parte más luminosa y soñadora de sí misma.
            </p>
            <p>
              Sin embargo, cuando las situaciones adversas de la vida empiezan a confrontarla, comprende que lleva tiempo sosteniendo una paz construida a costa de sí misma.
            </p>
            <p>
              Movida por una incomodidad que ya no puede ignorar, inicia un reencuentro íntimo con la vitalidad que un día tuvo y que abandonó para sobrevivir. En ese proceso, descubre que su mayor obstáculo no es el mundo exterior, sino las lealtades invisibles que la atan a una versión de sí misma que ya no la representa.
            </p>
            <p class="text-accent font-medium italic">
              Una voz al paso del eclipse es una historia que invita a detenerse, mirarse con honestidad y dejar la puerta abierta hacia una vida más auténtica.
            </p>
          </div>
        </div>
        <div class="lg:w-1/2 flex flex-col justify-center space-y-8">
          <!-- Frase destacada de la autora -->
          <div class="relative p-10 md:p-14 bg-background-light dark:bg-background-dark rounded-tr-[4rem] rounded-bl-[4rem] shadow-xl border border-secondary/10">
            <span class="material-symbols-outlined absolute top-8 left-8 text-6xl text-secondary/20" aria-hidden="true">format_quote</span>
            <blockquote class="relative z-10 text-center">
              <p class="font-display text-2xl md:text-3xl italic text-primary dark:text-white leading-relaxed mb-6">
                "Mirándome a través de los ojos de Natalia, comprendí que, al recuperar mi verdadera voz, volví a sonreír con la mirada"
              </p>
              <footer class="text-secondary font-display text-lg">— AdriCris Rueda</footer>
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Temáticas Section -->
  <section class="py-24 bg-surface-light dark:bg-background-dark relative" id="tematicas">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="text-accent font-bold tracking-[0.3em] uppercase text-xs block mb-4">Temáticas Centrales</span>
        <h2 class="font-display text-4xl md:text-5xl text-primary dark:text-white mb-6">El Acto Más Valiente: <br/><span class="italic text-secondary">Mirarse de Frente</span></h2>
        <div class="w-24 h-1 bg-secondary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="group bg-white dark:bg-surface-dark p-10 rounded-2xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-100 dark:border-gray-800 flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-6 rounded-full bg-secondary/10 flex items-center justify-center group-hover:bg-secondary group-hover:text-white text-secondary transition-colors duration-300">
            <span class="material-symbols-outlined text-3xl">visibility</span>
          </div>
          <h3 class="font-display text-2xl text-primary dark:text-white mb-4">Reconocimiento</h3>
          <p class="text-gray-600 dark:text-gray-400 font-light leading-relaxed">
            Aceptar nuestra historia completa, sin ediciones. El primer paso para sanar es validar cada herida y cada triunfo como parte integral de quiénes somos.
          </p>
        </div>
        <div class="group bg-white dark:bg-surface-dark p-10 rounded-2xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-100 dark:border-gray-800 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-secondary"></div>
          <div class="w-16 h-16 mb-6 rounded-full bg-secondary/10 flex items-center justify-center group-hover:bg-secondary group-hover:text-white text-secondary transition-colors duration-300">
            <span class="material-symbols-outlined text-3xl">favorite</span>
          </div>
          <h3 class="font-display text-2xl text-primary dark:text-white mb-4">Lealtad a Uno Mismo</h3>
          <p class="text-gray-600 dark:text-gray-400 font-light leading-relaxed">
            Romper con las expectativas ajenas para abrazar la propia verdad. Un compromiso inquebrantable con nuestro bienestar y autenticidad.
          </p>
        </div>
        <div class="group bg-white dark:bg-surface-dark p-10 rounded-2xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-100 dark:border-gray-800 flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-6 rounded-full bg-secondary/10 flex items-center justify-center group-hover:bg-secondary group-hover:text-white text-secondary transition-colors duration-300">
            <span class="material-symbols-outlined text-3xl">psychology_alt</span>
          </div>
          <h3 class="font-display text-2xl text-primary dark:text-white mb-4">Elecciones Conscientes</h3>
          <p class="text-gray-600 dark:text-gray-400 font-light leading-relaxed">
            Habitar la certeza de que la vida no es un viaje lineal, sino una serie de decisiones que nos acercan a nuestra identidad y autenticidad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Autora Section -->
  <section class="py-24 bg-background-light dark:bg-background-dark overflow-hidden relative" id="autora">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white dark:bg-surface-dark rounded-[3rem] overflow-hidden shadow-2xl relative">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-primary via-accent to-secondary"></div>
        <div class="grid grid-cols-1 lg:grid-cols-12">
          <div class="lg:col-span-5 relative min-h-[400px] lg:min-h-full">
            <img
              alt="Adriana Cristina Rueda Sañudo — Notas de la autora de Una Voz al paso del Eclipse"
              class="absolute inset-0 w-full h-full object-cover"
              src="/images/adriana-notas-autora.webp"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
            <div class="absolute bottom-0 left-0 p-8 bg-gradient-to-t from-black/80 to-transparent w-full">
              <p class="text-white font-display text-2xl">Adriana Cristina Rueda</p>
              <p class="text-secondary text-sm tracking-wider uppercase">Autora & Terapeuta Holística</p>
            </div>
          </div>
          <div class="lg:col-span-7 p-10 md:p-16 lg:p-20 flex flex-col justify-center">
            <span class="text-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Nota de la Autora</span>
            <h2 class="font-display text-3xl md:text-4xl text-primary dark:text-white mb-8">La Esencia Terapéutica Detrás de la Historia</h2>
            <div class="space-y-6 text-gray-600 dark:text-gray-300 font-light leading-relaxed">
              <p>
                "Escribir Una Voz al Paso del Eclipse no fue solo un ejercicio literario, sino un acto de confrontación. En la historia de Natalia quise plasmar procesos que veo a diario en mi consulta y que también he vivido en mi propia piel."
              </p>
              <p>
                "El eclipse es una metáfora central en esta historia. Hay momentos en la vida en los que ciertas experiencias proyectan una sombra que parece ocultar nuestra luz. Pero, como ocurre con el sol durante un eclipse, la luz no desaparece: sigue allí."
              </p>
              <p>
                "Este libro es una invitación a recordarlo. A reconocer que esas sombras no borran nuestra identidad, y que atravesarlas puede convertirse en el momento en que volvemos a escuchar con claridad nuestra propia voz."
              </p>
            </div>
            <div class="mt-10">
              <span class="font-display italic text-2xl text-secondary">AdriCris</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feria del Libro Section -->
  <section class="py-24 bg-surface-light dark:bg-surface-dark relative" id="comprar">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-12">
        <span class="material-symbols-outlined text-5xl text-accent mb-6 animate-pulse">menu_book</span>
        <h2 class="font-display text-4xl md:text-5xl text-primary dark:text-white mb-6">Feria del Libro de Bogotá 2026</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto font-light">
          Te espero en la Feria Internacional del Libro de Bogotá para compartir juntas este momento especial.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <!-- Imagen oficial FilBo -->
        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/filbo-2026-oficial.webp" 
                 alt="Afiche oficial Feria del Libro de Bogotá 2026 - Adriana Cristina Rueda"
                 class="w-full h-auto"
                 loading="lazy" decoding="async" />
          </div>
        </div>
        
        <!-- Calendario -->
        <div class="space-y-6">
          <h3 class="font-display text-2xl text-primary dark:text-white mb-4">Calendario de Presentaciones</h3>
          
          <div class="space-y-4">
            <div class="bg-white dark:bg-background-dark p-6 rounded-2xl shadow-lg border-l-4 border-secondary">
              <div class="flex items-start gap-4">
                <div class="bg-secondary/20 p-3 rounded-xl">
                  <span class="material-symbols-outlined text-secondary">event</span>
                </div>
                <div>
                  <p class="font-bold text-primary dark:text-white">Miércoles 22 de abril</p>
                  <p class="text-gray-600 dark:text-gray-300 text-sm">Conversatorio y firma de libros</p>
                  <p class="text-accent text-sm font-medium">Gran Salón A</p>
                </div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-background-dark p-6 rounded-2xl shadow-lg border-l-4 border-accent">
              <div class="flex items-start gap-4">
                <div class="bg-accent/20 p-3 rounded-xl">
                  <span class="material-symbols-outlined text-accent">event</span>
                </div>
                <div>
                  <p class="font-bold text-primary dark:text-white">Jueves 23, sábado 25 de abril y viernes 1° de mayo</p>
                  <p class="text-gray-600 dark:text-gray-300 text-sm">Presentaciones y firma de libros</p>
                  <p class="text-accent text-sm font-medium">Stand Editorial Utrilla (Área Internacional - Pabellón 17 - Stand 1919)</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Lanzamiento Amazon -->
          <div class="bg-primary/5 dark:bg-primary/10 p-6 rounded-2xl border border-primary/20 mb-6">
            <p class="text-sm text-primary dark:text-accent font-medium mb-2">Lanzamiento Amazon (Internacional)</p>
            <p class="text-gray-600 dark:text-gray-300">Mayo de 2026</p>
          </div>
          
          <!-- Agendar eventos -->
          <div class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-800">
            <p class="text-sm font-medium text-primary dark:text-white mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">calendar_add</span>
              Agregar al calendario
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Presentación+Una+Voz+al+paso+del+Eclipse+-+AdriCris+Rueda&dates=20260422/20260423&details=Conversatorio+y+firma+de+libros+con+Adriana+Cristina+Rueda+en+la+Feria+del+Libro+de+Bogotá+2026.&location=Gran+Salón+A,+Corferias,+Bogotá&sf=true&output=xml" 
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center justify-center gap-2 bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path fill="#4285F4" d="M22 12h-2v-2h-2v2h-2v2h2v2h2v-2h2z"/><path fill="#EA4335" d="M8 12H6v-2H4v2H2v2h2v2h2v-2h2z"/><path fill="#FBBC04" d="M14 6h-2V4h-2v2H8v2h2v2h2V8h2z"/><path fill="#34A853" d="M20 6h-2V4h-2v2h-2v2h2v2h2V8h2z"/></svg>
                Google Calendar
              </a>
              <a href="data:text/calendar;charset=utf8,BEGIN:VCALENDAR%0AVERSION:2.0%0ABEGIN:VEVENT%0ASUMMARY:Presentación Una Voz al paso del Eclipse - AdriCris Rueda%0ADESCRIPTION:Conversatorio y firma de libros con Adriana Cristina Rueda en la Feria del Libro de Bogotá 2026.%0ALOCATION:Gran Salón A, Corferias, Bogotá%0ADTSTART;VALUE=DATE:20260422%0ADTEND;VALUE=DATE:20260423%0AEND:VEVENT%0AEND:VCALENDAR" 
                 download="evento-adricris-rueda.ics"
                 class="inline-flex items-center justify-center gap-2 bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 22C7.79 22.05 6.8 20.68 5.96 19.47C4.25 17 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5M13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
                Apple Calendar
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- CTA Compra anticipada -->
      <div class="bg-white dark:bg-background-dark rounded-3xl p-8 md:p-12 shadow-xl border border-secondary/20 text-center">
        <span class="material-symbols-outlined text-5xl text-secondary mb-4">local_shipping</span>
        <h3 class="font-display text-3xl text-primary dark:text-white mb-4">Compra Anticipada</h3>
        <p class="text-gray-600 dark:text-gray-300 mb-6 max-w-xl mx-auto">
          ¡Ya tengo stock disponible! Realiza tu compra desde ya y te envío tu ejemplar personalizado. Envíos a todo Colombia.
        </p>
        <a href="https://wa.me/573132979675?text=Hola%20Adri!%20me%20gustaría%20comprar%20tu%20libro%20:)%20" 
           target="_blank" rel="noopener noreferrer"
           class="gold-gradient hover:opacity-90 text-primary px-10 py-4 rounded-full font-display font-bold text-lg shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1 inline-flex items-center gap-3">
          <span class="material-symbols-outlined">chat</span>
          COMPRAR POR WHATSAPP
        </a>
      </div>
    </div>
  </section>
  
  <!-- Newsletter Section -->
  <Newsletter />
</Layout>
