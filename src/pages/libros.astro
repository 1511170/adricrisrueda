---
import Layout from '../layouts/Layout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Layout
  title="Biblioteca del Alma | Libros de Adriana Cristina Rueda Sañudo"
  description="Descubre los libros de Adriana Cristina Rueda: 'Lazos Escritos' (2023) y 'Una Voz al paso del Eclipse' (2026). Literatura para el alma y el crecimiento espiritual."
  image="/images/portada-libro-2.png"
  keywords={['libros Adriana Rueda', 'Lazos Escritos', 'Una Voz al paso del Eclipse', 'literatura espiritual Colombia', 'autora colombiana']}
>
  <SchemaOrg
    slot="head"
    type={['Book']}
    data={{
      name: 'Lazos Escritos',
      genre: 'Antología',
      description: 'Colección de relatos sobre lazos humanos invisibles y conexiones del alma.',
      datePublished: '2023',
      url: 'https://adricrisrueda.com/libros',
    }}
  />
  <SchemaOrg
    slot="head"
    type={['BreadcrumbList']}
    breadcrumbs={[
      { name: 'Inicio', url: '/' },
      { name: 'Biblioteca', url: '/libros' },
    ]}
  />
  <!-- Hero Section -->
  <header class="relative min-h-[70vh] flex items-center justify-center pt-24 overflow-hidden bg-background-light dark:bg-background-dark">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[60%] bg-accent/15 dark:bg-accent/10 blur-[100px] rounded-full"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[45%] h-[55%] bg-secondary/15 dark:bg-secondary/10 blur-[100px] rounded-full"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full text-center">
      <div class="space-y-6">
        <span class="text-secondary tracking-[0.5em] uppercase text-xs font-semibold block">Colección Literaria</span>
        <h1 class="font-display text-6xl md:text-8xl lg:text-9xl leading-tight text-primary dark:text-white">
          Biblioteca<br/>
          <span class="italic text-accent font-light">del Alma</span>
        </h1>
        <div class="w-24 h-1 bg-secondary mx-auto rounded-full my-8"></div>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto font-light leading-relaxed">
          Cada libro es un peldaño en la escalera hacia la consciencia. Aquí encontrarás palabras que sanan, historias que reflejan y guías que iluminan el camino de regreso a ti.
        </p>
      </div>
      <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2">
        <a class="animate-bounce p-2 text-primary dark:text-accent/70 hover:text-secondary transition-colors" href="#featured">
          <span class="material-symbols-outlined text-4xl">keyboard_arrow_down</span>
        </a>
      </div>
    </div>
  </header>

  <!-- Quote Section -->
  <section class="py-32 bg-primary relative overflow-hidden flex items-center justify-center">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white"></path>
      </svg>
    </div>
    <div class="absolute top-0 left-0 w-64 h-64 bg-accent/20 blur-3xl rounded-full mix-blend-overlay"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-secondary/20 blur-3xl rounded-full mix-blend-overlay"></div>
    <div class="max-w-5xl mx-auto px-6 text-center relative z-10">
      <span class="material-symbols-outlined text-secondary/60 text-5xl mb-8 block">auto_stories</span>
      <blockquote class="font-display italic text-4xl md:text-6xl lg:text-7xl text-white leading-tight mb-8">
        "Escribir es construir puentes hacia lo invisible."
      </blockquote>
      <div class="w-16 h-0.5 bg-secondary mx-auto"></div>
    </div>
  </section>

  <!-- Catálogo Section -->
  <section class="py-24 bg-background-light dark:bg-background-dark relative" id="catalogo">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20">
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs block mb-4">Catálogo Completo</span>
        <h2 class="font-display text-4xl md:text-5xl text-primary dark:text-white">Obras Publicadas</h2>
      </div>
      
      <div class="space-y-16">
        <!-- Obra 1: Lazos Escritos -->
        <div class="bg-white dark:bg-surface-dark rounded-3xl p-8 lg:p-12 shadow-xl hover:shadow-2xl transition-shadow duration-300 border border-gray-100 dark:border-gray-800 flex flex-col lg:flex-row gap-12 items-center group">
          <!-- Imagen más pequeña -->
          <div class="w-40 md:w-48 flex-shrink-0 perspective-1000 relative">
            <div class="absolute inset-0 bg-secondary/20 blur-2xl rounded-full group-hover:bg-secondary/30 transition-colors"></div>
            <div class="aspect-[2/3] bg-surface-light dark:bg-gray-800 rounded shadow-lg flex items-center justify-center text-center p-2 relative z-10 transform group-hover:rotate-y-6 transition-transform duration-500 border border-gray-200 dark:border-gray-700 overflow-hidden">
              <img src="/images/lazos-escritos.png" alt="Portada Lazos Escritos — libro 2023 de Adriana Cristina Rueda Sañudo" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
          </div>
          <div class="flex-grow text-center lg:text-left">
            <div class="flex items-center justify-center lg:justify-start gap-3 mb-2">
              <span class="text-secondary font-bold text-sm">2023</span>
              <span class="px-2 py-0.5 bg-secondary/10 text-secondary text-xs font-bold uppercase tracking-wider rounded">Libro</span>
            </div>
            <h3 class="font-display text-3xl text-primary dark:text-white mb-4">Lazos Escritos</h3>
            
            <!-- Texto completo nuevo -->
            <div class="prose dark:prose-invert text-gray-600 dark:text-gray-300 font-light mb-6 text-left">
              <p class="mb-4">
                Mi primera obra, <em>Lazos Escritos (2023)</em>, presenta una guía de cinco pasos, basada en mi proceso de despertar de consciencia, partiendo desde la "noche oscura del alma", hasta lograr convertir esos momentos de vulnerabilidad en la base del propósito de vida.
              </p>
              <p class="mb-4">
                La conexión espiritual se convierte en una fuente de claridad y serenidad, que invita a vivir con mayor presencia. Además, contiene cuarenta mensajes canalizados, de Jesús, María y los Ángeles.
              </p>
              <p>
                Con este libro, mi mensaje ha llegado a lectores en diversos países, invitándolos a descubrir su propia voz interior y camino de sanación.
              </p>
            </div>
            
            <!-- Features -->
            <div class="space-y-2 mb-6">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary text-lg">auto_awesome</span>
                <span class="text-sm text-gray-600 dark:text-gray-300">40 mensajes canalizados</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary text-lg">menu_book</span>
                <span class="text-sm text-gray-600 dark:text-gray-300">Guía de 5 pasos de transformación</span>
              </div>
            </div>
            
            <!-- Botones -->
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="https://www.amazon.com/dp/B0CK3ZWGJN" target="_blank" rel="noopener noreferrer" 
                 class="gold-gradient text-primary px-6 py-3 rounded-full font-bold text-sm shadow-md hover:shadow-lg transition-all inline-flex items-center justify-center gap-2">
                COMPRAR EN AMAZON
                <span class="material-symbols-outlined text-base">shopping_bag</span>
              </a>
              <a href="https://wa.me/573132979675?text=Hola%2C%20me%20interesa%20comprar%20el%20libro%20Lazos%20Escritos" 
                 target="_blank" rel="noopener noreferrer"
                 class="bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-full font-bold text-sm transition-all inline-flex items-center justify-center gap-2">
                COMPRAR POR WHATSAPP
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Obra 2: Sus Huesos y Otros Cuentos -->
        <div class="bg-white dark:bg-surface-dark rounded-3xl p-8 lg:p-12 shadow-xl hover:shadow-2xl transition-shadow duration-300 border border-gray-100 dark:border-gray-800 flex flex-col lg:flex-row gap-8 items-center group">
          <div class="w-48 flex-shrink-0 perspective-1000 relative">
            <div class="absolute inset-0 bg-accent/20 blur-2xl rounded-full group-hover:bg-accent/30 transition-colors"></div>
            <div class="aspect-[2/3] bg-surface-light dark:bg-gray-800 rounded shadow-lg flex items-center justify-center text-center p-4 relative z-10 transform group-hover:rotate-y-6 transition-transform duration-500 border border-gray-200 dark:border-gray-700">
              <img src="/images/sus-huesos-antologia.jpg" alt="Portada antología Sus Huesos y Otros Cuentos — programa Autor de Éxito 2025" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
          </div>
          <div class="flex-grow text-center lg:text-left">
            <div class="flex items-center justify-center lg:justify-start gap-3 mb-2">
              <span class="text-accent font-bold text-sm">2025</span>
              <span class="px-2 py-0.5 bg-accent/10 text-accent text-xs font-bold uppercase tracking-wider rounded">Antología</span>
              <span class="px-2 py-0.5 bg-primary/10 text-primary dark:text-accent text-xs font-bold uppercase tracking-wider rounded">Autor de Éxito</span>
            </div>
            <h3 class="font-display text-3xl text-primary dark:text-white mb-2 leading-tight">Sus Huesos y Otros Cuentos</h3>
            <p class="text-secondary font-medium mb-4 text-lg italic">"Los árboles que se miraron al espejo"</p>
            <p class="text-gray-600 dark:text-gray-300 font-light mb-4">
              Una fábula que explora el valor de habitar la identidad en medio de las diferencias.
            </p>
            <div class="flex items-center gap-4 justify-center lg:justify-start">
              <div class="relative group/diploma cursor-pointer" onclick="document.getElementById('diploma-modal').classList.remove('hidden')">
                <img src="/images/sus-huesos-diploma.jpg" alt="Diploma programa Autor de Éxito" class="w-28 h-20 object-cover rounded border border-gray-200 dark:border-gray-700 group-hover/diploma:shadow-lg transition-all" loading="lazy" />
                <div class="absolute inset-0 bg-black/0 group-hover/diploma:bg-black/10 transition-colors rounded flex items-center justify-center">
                  <span class="material-symbols-outlined text-white opacity-0 group-hover/diploma:opacity-100 transition-opacity text-2xl">zoom_in</span>
                </div>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">Reconocimiento 31 octubre 2025<br><span class="text-accent">Click para ampliar</span></span>
            </div>
            
            <!-- Modal Diploma -->
            <div id="diploma-modal" class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4" onclick="this.classList.add('hidden')">
              <div class="relative max-w-4xl w-full">
                <button class="absolute -top-12 right-0 text-white hover:text-secondary transition-colors" onclick="document.getElementById('diploma-modal').classList.add('hidden')">
                  <span class="material-symbols-outlined text-4xl">close</span>
                </button>
                <img src="/images/sus-huesos-diploma.jpg" alt="Diploma programa Autor de Éxito - Vista completa" class="w-full h-auto rounded-lg shadow-2xl" />
              </div>
            </div>
          </div>
        </div>

        <!-- Obra 3: Una Voz al Paso del Eclipse -->
        <div class="bg-white dark:bg-surface-dark rounded-3xl p-8 lg:p-12 shadow-xl hover:shadow-2xl transition-shadow duration-300 border border-gray-100 dark:border-gray-800 flex flex-col lg:flex-row gap-8 items-center group">
          <div class="w-48 flex-shrink-0 perspective-1000 relative">
            <div class="absolute inset-0 bg-primary/20 blur-2xl rounded-full group-hover:bg-primary/30 transition-colors"></div>
            <div class="aspect-[2/3] bg-surface-light dark:bg-gray-800 rounded shadow-lg flex items-center justify-center text-center p-4 relative z-10 transform group-hover:rotate-y-6 transition-transform duration-500 border border-gray-200 dark:border-gray-700">
              <img src="/images/portada-libro-2.png" alt="Portada Una Voz al paso del Eclipse — libro de crecimiento espiritual por AdriCris Rueda, 2026" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
          </div>
          <div class="flex-grow text-center lg:text-left">
            <div class="flex items-center justify-center lg:justify-start gap-3 mb-2">
              <span class="text-primary dark:text-accent font-bold text-sm">2026</span>
              <span class="px-2 py-0.5 bg-primary/10 text-primary dark:text-accent text-xs font-bold uppercase tracking-wider rounded">Libro</span>
              <span class="px-2 py-0.5 bg-secondary/10 text-secondary text-xs font-bold uppercase tracking-wider rounded">Disponible</span>
            </div>
            <h3 class="font-display text-3xl text-primary dark:text-white mb-4 leading-tight">Una Voz al Paso del Eclipse</h3>
            <p class="text-accent font-medium mb-4 text-sm uppercase tracking-wide">Crecimiento Espiritual</p>
            <p class="text-gray-600 dark:text-gray-300 font-light mb-6">
              Mi obra más personal. Un recorrido íntimo por situaciones que nos hicieron creer que vivíamos en la oscuridad, cuando en realidad solo necesitábamos reencontrarnos con nuestra propia luz.
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="https://wa.me/573132979675?text=Hola%20Adri!%20me%20gustaría%20comprar%20tu%20libro%20Una%20Voz%20al%20paso%20del%20Eclipse%20:)%20" target="_blank" rel="noopener noreferrer" class="gold-gradient text-primary px-6 py-2 rounded-full font-bold text-sm shadow-md hover:shadow-lg transition-all inline-flex items-center justify-center gap-2">
                COMPRAR
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href="/libro" class="bg-transparent border border-primary dark:border-gray-400 text-primary dark:text-gray-200 px-6 py-2 rounded-full font-bold text-sm hover:bg-primary hover:text-white dark:hover:bg-white dark:hover:text-primary transition-all inline-flex items-center justify-center gap-2">
                VER LIBRO
                <span class="material-symbols-outlined text-base">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <Newsletter />
</Layout>
