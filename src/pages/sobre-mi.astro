---
import Layout from '../layouts/Layout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
---

<Layout
  title="Sobre Mí | Adriana Cristina Rueda Sañudo — Terapeuta & Autora"
  description="De arquitecta a terapeuta holística. Conoce la historia de Adriana Cristina Rueda Sañudo, Reikista, Pinealista, Canalizadora y Autora de 'Lazos Escritos'. Bogotá, Colombia."
  image="/images/adriana-bio.png"
  keywords={['Adriana Cristina Rueda Sañudo', 'terapeuta holística', 'Reiki Bogotá', 'autora colombiana', 'Lazos Escritos']}
>
  <SchemaOrg slot="head" type={['AboutPage']} />
  <SchemaOrg
    slot="head"
    type={['BreadcrumbList']}
    breadcrumbs={[
      { name: 'Inicio', url: '/' },
      { name: 'Sobre Mí', url: '/sobre-mi' },
    ]}
  />
  <!-- Hero Section -->
  <header class="relative min-h-[90vh] flex items-center justify-center pt-24 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[10%] right-[5%] w-[45%] h-[55%] bg-accent/20 dark:bg-accent/10 blur-[80px] rounded-[30%_70%_70%_30%_/_30%_30%_70%_70%] animate-blob"></div>
      <div class="absolute bottom-[10%] left-[5%] w-[40%] h-[50%] bg-secondary/20 dark:bg-secondary/10 blur-[90px] rounded-[70%_30%_30%_70%_/_60%_40%_60%_40%] animate-blob animation-delay-2000"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 text-center lg:text-left space-y-8 animate-float">
          <div class="inline-block">
            <span class="text-secondary tracking-[0.4em] uppercase text-sm font-semibold mb-2 block">Terapeuta & Autora</span>
          </div>
          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-none text-primary dark:text-white">
            Adriana<br/>
            <span class="italic text-accent font-light">Cristina</span><br/>
            Rueda Sañudo
          </h1>
          <div class="w-32 h-1 bg-secondary lg:mx-0 mx-auto rounded-full"></div>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-lg mx-auto lg:mx-0 font-light leading-relaxed">
            Explorando la arquitectura del alma, construyendo puentes hacia la consciencia y escribiendo la luz que habita en nuestras sombras.
          </p>
          <div class="flex items-center gap-3 justify-center lg:justify-start pt-2">
            <a href="https://www.instagram.com/adricrisrueda/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-11 h-11 rounded-full border border-secondary/30 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:text-secondary hover:border-secondary transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.468 2.53c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="https://www.facebook.com/adricrisrueda/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-11 h-11 rounded-full border border-secondary/30 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:text-secondary hover:border-secondary transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="https://www.youtube.com/@adricrisrueda" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-11 h-11 rounded-full border border-secondary/30 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:text-secondary hover:border-secondary transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" />
              </svg>
            </a>

          </div>
        </div>
        <div class="order-1 lg:order-2 relative flex justify-center lg:justify-end perspective-1000">
          <div class="relative w-72 h-80 md:w-[28rem] md:h-[34rem] lg:w-[32rem] lg:h-[40rem]">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-accent/20 to-secondary/20 blur-3xl rounded-full"></div>
            <div class="relative w-full h-full organic-border-2 overflow-hidden shadow-2xl border-4 border-white/40 dark:border-white/10 ring-1 ring-secondary/30">
              <img
                alt="Adriana Cristina Rueda Sañudo — Terapeuta Holística, Autora y Guía Espiritual, Bogotá Colombia"
                class="w-full h-full object-cover"
                src="/images/adriana-bio.png"
                loading="eager"
                fetchpriority="high"
                decoding="sync"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent mix-blend-multiply"></div>
            </div>
            <div class="absolute bottom-10 -left-6 bg-white/90 dark:bg-surface-dark/90 backdrop-blur-md p-6 rounded-2xl shadow-xl border border-secondary/20 max-w-[240px] z-20 animate-float" style="animation-delay: 1.5s;">
              <p class="font-display text-2xl text-primary dark:text-accent italic">"Tu voz es el puente"</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
      <a class="animate-bounce p-2 text-primary dark:text-accent/70 hover:text-secondary transition-colors" href="#biografia">
        <span class="material-symbols-outlined text-4xl">keyboard_arrow_down</span>
      </a>
    </div>
  </header>

  <!-- Biografía Section -->
  <section class="py-24 bg-white dark:bg-surface-dark relative" id="biografia">
    <div class="absolute top-0 left-0 w-32 h-full bg-surface-light dark:bg-black/20 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
        <div class="w-full lg:w-5/12 relative">
          <div class="sticky top-32">
            <div class="relative rounded-t-[10rem] rounded-b-xl overflow-hidden shadow-2xl h-[600px] w-full group bg-white dark:bg-gray-900">
              <img
                alt="Adriana Cristina Rueda Sañudo — de arquitecta a terapeuta holística, Bogotá Colombia"
                class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
                src="/images/adriana-servicios.png"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-primary/20 group-hover:bg-primary/10 transition-colors duration-500"></div>
              <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black/80 to-transparent">
                <span class="text-secondary font-display italic text-2xl"></span>
              </div>
            </div>
            <div class="absolute -z-10 -bottom-10 -right-10 w-40 h-40 bg-secondary/10 rounded-full blur-2xl"></div>
            <div class="absolute -z-10 top-20 -left-10 w-24 h-24 bg-accent/20 rounded-full blur-xl"></div>
          </div>
        </div>
        <div class="w-full lg:w-7/12 py-8">
          <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-primary dark:text-white mb-8 leading-tight">
            Mi Camino: <br/>
            <span class="text-accent italic font-light">De la Estructura a la Esencia</span>
          </h2>
          <div class="space-y-6 text-gray-600 dark:text-gray-300 font-light text-lg leading-relaxed">
            <p>
              <span class="float-left text-5xl pr-4 mt-2 font-display text-secondary">D</span>urante varios años mi vida estuvo dedicada a la arquitectura, los planos y las estructuras concretas. Como arquitecta y profesional en Tecnologías de Información, me movía en un mundo donde el orden, la lógica y la precisión eran fundamentales. Con el tiempo empecé a sentir un interés cada vez más profundo por el mundo interior y por las preguntas que surgen cuando una persona busca comprenderse a sí misma más allá de lo visible. Ese proceso me llevó a explorar distintos caminos de crecimiento personal y espiritual, y poco a poco fui integrando estas experiencias en mi vida y en mi forma de acompañar a otros. Hoy, como terapeuta holística y coach espiritual, facilito espacios de reflexión y acompañamiento a través de terapias, talleres y procesos de crecimiento personal. En mi trabajo integro prácticas de sanación energética, intuición y escritura como caminos de conexión interior y transformación personal.
            </p>
            <div class="pt-6 grid grid-cols-2 gap-6">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-accent text-3xl">person</span>
                <span class="text-sm font-medium uppercase tracking-wider">Mujer real</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary text-3xl">self_improvement</span>
                <span class="text-sm font-medium uppercase tracking-wider">Terapeuta Holística</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary dark:text-accent text-3xl">menu_book</span>
                <span class="text-sm font-medium uppercase tracking-wider">Autora</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary text-3xl">group</span>
                <span class="text-sm font-medium uppercase tracking-wider">Coach Espiritual</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Section -->
  <section class="py-32 bg-accent relative overflow-hidden flex items-center justify-center">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white"></path>
      </svg>
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <span class="material-symbols-outlined text-white/40 text-6xl mb-6 block">format_quote</span>
      <h3 class="font-display text-3xl md:text-5xl lg:text-6xl text-white leading-tight mb-8">
        La autenticidad no es algo que tenemos o no tenemos.<br/>
        <span class="italic font-light opacity-90">Es una práctica de soltar quienes creemos que debemos ser y abrazar quienes realmente somos.</span>
      </h3>
      <div class="w-24 h-1 bg-secondary mx-auto mb-4"></div>
      <p class="text-white font-body uppercase tracking-widest text-sm">Adriana Cristina Rueda</p>
    </div>
  </section>

  <!-- Testimonios y Entrevistas Section -->
  <section class="py-24 bg-background-light dark:bg-background-dark overflow-hidden" id="testimonios">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs block mb-4">Voces que han transitado el camino</span>
        <h2 class="font-display text-4xl md:text-5xl text-primary dark:text-white mb-4">Testimonios</h2>
        <p class="text-gray-500 font-light max-w-2xl mx-auto">
          Experiencias de quienes han encontrado en el acompañamiento un espacio de transformación.
        </p>
      </div>
      
      <!-- Grid de Testimonios (Placeholder para futuros testimonios) -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        <!-- Testimonio 1 -->
        <div class="bg-white dark:bg-surface-dark rounded-2xl p-8 shadow-lg border border-gray-100 dark:border-gray-800">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
          </div>
          <p class="text-gray-600 dark:text-gray-300 font-light italic mb-6">
            "Adriana tiene una capacidad única de escuchar más allá de las palabras. Su acompañamiento me ayudó a reconectar con mi voz interior."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-accent">person</span>
            </div>
            <div>
              <p class="font-medium text-primary dark:text-white text-sm">María Elena G.</p>
              <p class="text-xs text-gray-400">Bogotá, Colombia</p>
            </div>
          </div>
        </div>

        <!-- Testimonio 2 -->
        <div class="bg-white dark:bg-surface-dark rounded-2xl p-8 shadow-lg border border-gray-100 dark:border-gray-800">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
          </div>
          <p class="text-gray-600 dark:text-gray-300 font-light italic mb-6">
            "Las mentorías de 'Autoras con Propósito' transformaron mi relación con la escritura. Encontré el coraje para contar mi historia."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-secondary/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-secondary">person</span>
            </div>
            <div>
              <p class="font-medium text-primary dark:text-white text-sm">Laura P.</p>
              <p class="text-xs text-gray-400">Miembro de Autoras con Propósito</p>
            </div>
          </div>
        </div>

        <!-- Testimonio 3 -->
        <div class="bg-white dark:bg-surface-dark rounded-2xl p-8 shadow-lg border border-gray-100 dark:border-gray-800">
          <div class="flex items-center gap-1 mb-4">
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
            <span class="material-symbols-outlined text-secondary text-xl">star</span>
          </div>
          <p class="text-gray-600 dark:text-gray-300 font-light italic mb-6">
            "En la comunidad 'Confío y Creo en Mí' encontré un espacio seguro para sanar. El acompañamiento de Adriana es cálido y profundamente transformador."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary dark:text-accent">person</span>
            </div>
            <div>
              <p class="font-medium text-primary dark:text-white text-sm">Carolina M.</p>
              <p class="text-xs text-gray-400">Comunidad Confío y Creo en Mí</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider -->
      <div class="w-24 h-0.5 bg-secondary/30 mx-auto mb-16"></div>

      <!-- Entrevistas y Medios -->
      <div class="text-center mb-12">
        <span class="text-accent font-bold tracking-[0.3em] uppercase text-xs block mb-4">En los medios</span>
        <h3 class="font-display text-3xl md:text-4xl text-primary dark:text-white">Entrevistas</h3>
      </div>

      <!-- Podcast Spotify -->
      <div class="max-w-3xl mx-auto bg-white dark:bg-surface-dark rounded-2xl p-8 shadow-lg border border-gray-100 dark:border-gray-800">
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="w-20 h-20 rounded-full bg-[#1DB954] flex items-center justify-center flex-shrink-0">
            <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
          </div>
          <div class="flex-grow text-center md:text-left">
            <span class="text-xs text-gray-400 uppercase tracking-wider">Podcast</span>
            <h4 class="font-display text-xl text-primary dark:text-white mb-2">Entrevista en Spotify</h4>
            <p class="text-gray-500 font-light text-sm mb-4">
              Una conversación sobre escritura terapéutica, sanación y el poder de contar nuestra historia.
            </p>
            <a href="https://open.spotify.com/episode/70yA6Lh3IXwmAq138Tp9ga?si=kTbAZpTPTRqN0YSXNaq9Og" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[#1DB954] hover:text-[#1ed760] font-medium transition-colors">
              <span class="material-symbols-outlined text-base">play_circle</span>
              Escuchar en Spotify
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contacto Section -->
  <section class="py-24 bg-surface-light dark:bg-surface-dark relative border-t border-gray-200 dark:border-gray-800" id="contacto">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="material-symbols-outlined text-secondary text-5xl mb-6 block mx-auto">mail_outline</span>
      <h2 class="font-display text-4xl md:text-5xl text-gray-900 dark:text-white mb-6">
        Continuemos la conversación
      </h2>
      <p class="text-gray-600 dark:text-gray-300 font-light text-lg mb-10 leading-relaxed">
        Si mi historia resuena contigo, o si sientes el llamado a explorar tu voz interior, estaré encantada de escucharte. Ya sea para una consulta, una colaboración o simplemente para compartir experiencias.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a class="gold-gradient text-primary px-10 py-4 rounded-full font-display font-bold shadow-xl hover:shadow-2xl hover:scale-105 transition-all flex items-center justify-center gap-2" href="mailto:adriana@adricrisrueda.com">
          <span class="material-symbols-outlined">send</span>
          ENVIAR MENSAJE
        </a>
        <a href="/servicios" class="px-10 py-4 rounded-full font-display border border-primary/20 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 transition-all flex items-center justify-center gap-2">
          <span class="material-symbols-outlined">calendar_month</span>
          AGENDA TU CITA
        </a>
      </div>
      <div class="flex items-center justify-center gap-4 mt-10">
