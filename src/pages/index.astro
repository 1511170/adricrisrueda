---
import Layout from '../layouts/Layout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
---

<Layout
  title="AdriCris Rueda | Terapeuta Holística, Autora & Guía Espiritual"
  description="Adriana Cristina Rueda Sañudo — Terapeuta Holística, Reikista, Pinealista y Autora. Descubre 'Una Voz al paso del Eclipse' y los servicios de sanación. Bogotá, Colombia."
  image="/images/portada-libro-2.png"
  keywords={['terapeuta holística Bogotá', 'Reiki Colombia', 'sanación espiritual', 'Una Voz al paso del Eclipse', 'AdriCris Rueda', 'autora colombiana']}
>
  <SchemaOrg slot="head" type={['LocalBusiness']} />
  <!-- Hero Section -->
  <header id="inicio" class="relative min-h-screen flex items-center justify-center pt-24 overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-[10%] -right-[5%] w-[60%] h-[60%] bg-accent/10 dark:bg-accent/5 blur-[100px] rounded-full animate-blob"></div>
      <div class="absolute top-[20%] -left-[10%] w-[50%] h-[50%] bg-secondary/10 dark:bg-secondary/5 blur-[80px] rounded-full animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-[10%] left-[20%] w-[30%] h-[30%] bg-primary/5 dark:bg-primary/10 blur-[60px] rounded-full animate-blob animation-delay-4000"></div>
      <svg class="absolute top-0 right-0 w-full h-full opacity-20 dark:opacity-10 z-0" preserveAspectRatio="none" viewBox="0 0 100 100">
        <path class="text-secondary" d="M0 0 C 30 20 70 20 100 0 L 100 100 L 0 100" fill="none" stroke="currentColor" stroke-width="0.2"></path>
        <path class="text-accent" d="M0 40 C 30 60 70 30 100 60" fill="none" stroke="currentColor" stroke-width="0.1"></path>
      </svg>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text Content -->
        <div class="order-2 lg:order-1 text-center lg:text-left space-y-8">
          <div class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-surface-light border border-secondary/20 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
            <span class="text-primary dark:text-primary text-xs font-bold tracking-[0.2em] uppercase">Disponible</span>
          </div>
          
          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[1.1]">
            <span class="text-gradient block mb-1">Una Voz</span>
            <span class="text-gray-800 dark:text-gray-200 font-light text-4xl md:text-6xl lg:text-7xl block mt-2">al paso del Eclipse</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-lg mx-auto lg:mx-0 font-light leading-relaxed tracking-wide">
            Una historia que invita a mirarte con honestidad, recordar quién fuiste y dejar la puerta abierta hacia una vida más auténtica.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start pt-6">
            <a href="/libro" class="group relative overflow-hidden bg-accent text-white px-10 py-4 rounded-full font-display transition-all transform hover:-translate-y-1 shadow-lg shadow-accent/30 hover:shadow-accent/50">
              <span class="relative z-10 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-lg">auto_stories</span>
                COMPRAR LIBRO
              </span>
            </a>
            <a href="#servicios" class="group relative overflow-hidden bg-secondary text-primary px-10 py-4 rounded-full font-display transition-all transform hover:-translate-y-1 shadow-lg shadow-secondary/30 hover:shadow-secondary/50">
              <span class="relative z-10 flex items-center justify-center gap-2">
                VER SERVICIOS
                <span class="material-symbols-outlined text-lg">arrow_forward</span>
              </span>
              <div class="absolute inset-0 bg-accent transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500 ease-out"></div>
            </a>
          </div>
        </div>
        
        <!-- Image -->
        <div class="order-1 lg:order-2 relative flex justify-center items-start">
          <div class="relative w-full h-full max-w-[400px] animate-float" style="perspective: 1000px;">
            <div class="absolute inset-0 bg-secondary/30 blur-3xl rounded-[40%] animate-pulse"></div>
            <!-- Portada -->
            <div class="relative w-full h-full shadow-[15px_5px_40px_rgba(0,0,0,0.4)] transform rotate-y-2deg">
              <img
                src="/images/portada-libro-2.png"
                alt="Portada oficial del libro Una Voz al paso del Eclipse — Adriana Cristina Rueda Sañudo, Feria del Libro de Bogotá 2026"
                class="w-full h-full object-contain"
                loading="eager"
                fetchpriority="high"
                decoding="sync"
              />
            </div>
          </div>
          <!-- Badge -->
          <div class="absolute -bottom-4 -right-2 md:bottom-8 md:-right-6 bg-surface-light/90 dark:bg-surface-dark/90 backdrop-blur-sm p-5 rounded-2xl shadow-xl border border-white/50 dark:border-gray-700 max-w-[200px] z-20 animate-float" style="animation-delay: 1s;">
            <div class="flex items-center gap-2 mb-1">
              <span class="material-symbols-outlined text-secondary text-sm">verified</span>
              <p class="font-display font-bold text-primary dark:text-accent text-lg">AdriCris Rueda</p>
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 font-light tracking-wide uppercase">Terapeuta Holística & Autora</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2">
      <a href="#libro" class="flex flex-col items-center text-primary dark:text-accent/70 hover:text-secondary transition-colors group">
        <span class="text-[0.6rem] uppercase tracking-widest mb-2 opacity-0 group-hover:opacity-100 transition-opacity">Descubre Más</span>
        <span class="material-symbols-outlined text-3xl animate-bounce">keyboard_arrow_down</span>
      </a>
    </div>
  </header>

  <!-- About Section -->
  <section id="sobre-mi" class="py-24 bg-background-light dark:bg-background-dark relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-surface-light dark:from-surface-dark to-transparent opacity-50"></div>
    </div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-sm md:text-base block mb-4">La Guía</span>
        <h2 class="font-display text-4xl md:text-5xl text-gray-900 dark:text-white mb-2">Adriana Cristina Rueda Sañudo</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-transparent via-accent to-transparent mx-auto mt-4"></div>
      </div>
      
      <div class="relative bg-white dark:bg-surface-dark rounded-[3rem] p-8 md:p-14 shadow-2xl border border-gray-100 dark:border-gray-800">
        <div class="absolute -top-10 -left-10 w-32 h-32 bg-secondary/20 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-accent/20 rounded-full blur-2xl"></div>
        
        <div class="flex flex-col md:flex-row gap-12 items-center">
          <!-- Profile Image -->
          <div class="w-40 h-40 md:w-56 md:h-56 flex-shrink-0 relative group">
            <div class="absolute inset-0 rounded-full border-2 border-dashed border-secondary/50 animate-[spin_12s_linear_infinite]"></div>
            <div class="absolute inset-2 rounded-full border border-primary/20 animate-[spin_15s_linear_infinite_reverse]"></div>
            <div class="absolute inset-0 rounded-full bg-secondary/20 blur-xl opacity-0 group-hover:opacity-60 transition-opacity duration-500"></div>
            <img
              src="/images/adriana-perfil.png"
              alt="Adriana Cristina Rueda Sañudo — Terapeuta Holística, Autora y Guía Espiritual, Bogotá Colombia"
              class="w-full h-full object-cover rounded-full border-4 border-white dark:border-gray-700 relative z-10 shadow-lg"
              loading="lazy"
              decoding="async"
            />
          </div>
          
          <!-- Bio Text -->
          <div class="text-gray-600 dark:text-gray-300 text-justify relative z-10 font-light">
            <span class="material-symbols-outlined absolute -top-8 -left-4 text-6xl text-gray-100 dark:text-gray-800 -z-10 rotate-180">format_quote</span>
            <p class="mb-6 leading-relaxed">
              Terapeuta holística, coach espiritual y escritora.
            </p>
            <p class="mb-6 leading-relaxed">
              Acompaño procesos de autoconocimiento y crecimiento interior a través de terapias, talleres y cursos.
            </p>
            <p class="leading-relaxed">
              Dirijo las mentorías de escritura <strong class="text-secondary font-display text-lg">"Autoras con Propósito"</strong> y la comunidad espiritual <strong class="text-secondary font-display text-lg">"Confío y Creo en Mí"</strong>, espacios dedicados al desarrollo personal y la vida consciente.
            </p>
            <div class="mt-8 flex justify-end">
              <span class="font-display italic text-accent">Bogotá, Colombia</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="servicios" class="py-24 bg-surface-light dark:bg-surface-dark transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div class="max-w-2xl">
          <h2 class="font-display text-4xl md:text-5xl text-gray-900 dark:text-white mb-6">Servicios Holísticos</h2>
          <p class="text-gray-600 dark:text-gray-400 text-lg font-light border-l-4 border-secondary pl-4">
            Espacios sagrados diseñados para tu evolución, sanación y despertar de conciencia.
          </p>
        </div>
        <a href="/servicios" class="hidden md:inline-flex items-center gap-2 text-primary dark:text-secondary font-bold hover:gap-4 transition-all">
          VER TODO EL CATÁLOGO <span class="material-symbols-outlined">arrow_right_alt</span>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="group bg-background-light dark:bg-background-dark rounded-[2rem] p-10 hover:shadow-2xl transition-all duration-500 relative overflow-hidden border border-transparent hover:border-accent/20">
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-accent/10 rounded-full blur-2xl group-hover:bg-accent/20 transition-colors"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 rounded-2xl bg-white dark:bg-surface-dark shadow-sm flex items-center justify-center mb-8 text-primary dark:text-accent group-hover:scale-110 transition-transform duration-300 rotate-3 group-hover:rotate-0">
              <span class="material-symbols-outlined text-3xl">spa</span>
            </div>
            <h3 class="font-display text-2xl text-gray-900 dark:text-white mb-4">Terapia Holística</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-8 font-light leading-relaxed text-sm">
              Sesiones personalizadas de sanación intuitiva canalizada, combinando Reiki, cristaloterapia y mensajes de luz para equilibrar tu energía.
            </p>
            <a href="/servicios" class="inline-flex items-center text-primary dark:text-secondary font-semibold text-sm tracking-wide uppercase hover:underline decoration-2 underline-offset-4">
              Más información
            </a>
          </div>
        </div>
        
        <!-- Service 2 -->
        <div class="group bg-background-light dark:bg-background-dark rounded-[2rem] p-10 hover:shadow-2xl transition-all duration-500 relative overflow-hidden border border-transparent hover:border-secondary/20">
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-secondary/10 rounded-full blur-2xl group-hover:bg-secondary/20 transition-colors"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 rounded-2xl bg-white dark:bg-surface-dark shadow-sm flex items-center justify-center mb-8 text-secondary group-hover:scale-110 transition-transform duration-300 -rotate-2 group-hover:rotate-0">
              <span class="material-symbols-outlined text-3xl">school</span>
            </div>
            <h3 class="font-display text-2xl text-gray-900 dark:text-white mb-4">Talleres y Cursos</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-8 font-light leading-relaxed text-sm">
              Formación en crecimiento espiritual, canalización, escritura creativa y terapéutica, y herramientas prácticas para la vida consciente.
            </p>
            <a href="/servicios" class="inline-flex items-center text-primary dark:text-secondary font-semibold text-sm tracking-wide uppercase hover:underline decoration-2 underline-offset-4">
              Ver Calendario
            </a>
          </div>
        </div>
        
        <!-- Service 3 -->
        <div class="group bg-background-light dark:bg-background-dark rounded-[2rem] p-10 hover:shadow-2xl transition-all duration-500 relative overflow-hidden border border-transparent hover:border-primary/20">
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-colors"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 rounded-2xl bg-white dark:bg-surface-dark shadow-sm flex items-center justify-center mb-8 text-primary dark:text-accent group-hover:scale-110 transition-transform duration-300 rotate-3 group-hover:rotate-0">
              <span class="material-symbols-outlined text-3xl">diversity_1</span>
            </div>
            <h3 class="font-display text-2xl text-gray-900 dark:text-white mb-4">Comunidad</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-8 font-light leading-relaxed text-sm">
              Un espacio de apoyo espiritual continuo, meditaciones grupales y acompañamiento en tu proceso de despertar. "Confío y Creo en Mí".
            </p>
            <a href="/servicios" class="inline-flex items-center text-primary dark:text-secondary font-semibold text-sm tracking-wide uppercase hover:underline decoration-2 underline-offset-4">
              Unirse
            </a>
          </div>
        </div>
      </div>
      
      <div class="mt-8 text-center md:hidden">
        <button class="inline-flex items-center gap-2 text-primary dark:text-secondary font-bold hover:gap-4 transition-all">
          VER TODO EL CATÁLOGO <span class="material-symbols-outlined">arrow_right_alt</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-24 relative overflow-hidden bg-primary dark:bg-background-dark">
    <svg class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none" preserveAspectRatio="none" viewBox="0 0 100 100">
      <path d="M0 50 Q 25 30 50 50 T 100 50 V 100 H 0 Z" fill="white"></path>
    </svg>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <span class="material-symbols-outlined text-7xl md:text-8xl text-secondary mb-6 block mx-auto animate-bounce">mark_email_unread</span>
      <h2 class="font-display text-4xl md:text-5xl text-white mb-6 leading-tight">Comienza tu viaje hacia una<br/> <span class="text-secondary italic">Vida Consciente</span></h2>
      <p class="text-gray-200 font-light text-lg mb-10 max-w-2xl mx-auto">
        Suscríbete para recibir meditaciones gratuitas, novedades sobre talleres y capítulos exclusivos de mi nuevo libro.
      </p>
      <!-- Gift Banner -->
      <div class="bg-secondary/20 backdrop-blur-sm border border-secondary/30 rounded-2xl p-6 mb-8 max-w-lg mx-auto">
        <div class="flex items-center justify-center gap-3 mb-2">
          <span class="material-symbols-outlined text-3xl text-secondary">redeem</span>
          <span class="text-secondary font-bold">REGALO EXCLUSIVO</span>
        </div>
        <p class="text-white font-display text-xl mb-1">Descarga Gratis: 30 Tips de Vida</p>
        <p class="text-gray-300 text-sm">Al suscribirte recibirás instantáneamente este PDF con consejos prácticos para vivir con mayor consciencia.</p>
      </div>
      
      <form action="https://formsubmit.co/adriana@adricrisrueda.com" method="POST" class="flex flex-col gap-4 justify-center max-w-lg mx-auto relative">
        <!-- Configuración Formsubmit -->
        <input type="hidden" name="_next" value="https://adricrisrueda.com/gracias">
        <input type="hidden" name="_subject" value="Nueva suscripción a Vida Consciente">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_template" value="table">
        
        <input 
          type="text" 
          name="nombre"
          placeholder="Tu nombre" 
          class="w-full px-8 py-4 rounded-full text-gray-900 bg-surface-light focus:ring-2 focus:ring-secondary focus:outline-none border-none shadow-xl font-light placeholder-gray-400"
          required
        />
        <input 
          type="email" 
          name="email"
          placeholder="Tu correo electrónico" 
          class="w-full px-8 py-4 rounded-full text-gray-900 bg-surface-light focus:ring-2 focus:ring-secondary focus:outline-none border-none shadow-xl font-light placeholder-gray-400"
          required
        />
        <label class="flex items-start gap-3 text-left cursor-pointer">
          <input type="checkbox" required class="mt-1 w-5 h-5 rounded border-gray-300 text-secondary focus:ring-secondary flex-shrink-0">
          <span class="text-sm text-white/80">
            Acepto el tratamiento de mis datos personales según la <a href="/privacidad" class="underline hover:text-secondary transition-colors">Política de Privacidad</a>
          </span>
        </label>
        <button 
          type="submit"
          class="bg-secondary text-primary font-bold px-10 py-4 rounded-full hover:bg-white hover:text-primary transition-colors shadow-lg shadow-secondary/30 whitespace-nowrap tracking-wide mt-2 inline-flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">mail</span>
          SUSCRIBIRME Y RECIBIR MI PDF
        </button>
      </form>
      <p class="text-xs text-white/40 mt-6 font-light">Unimos fuerzas con tu privacidad. Sin spam, solo esencia.</p>
    </div>
  </section>
</Layout>

<!-- Schema.org Person -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Adriana Cristina Rueda Sañudo",
  "alternateName": "AdriCris Rueda",
  "description": "Terapeuta Holística, Autora y Guía Espiritual. Creadora del método SWAMI OM HARI y autora de 'Lazos Escritos' y 'Una Voz al paso del Eclipse'.",
  "url": "https://adricrisrueda.com",
  "jobTitle": "Terapeuta Holística",
  "worksFor": {
    "@type": "Organization",
    "name": "Vida Consciente"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bogotá",
    "addressCountry": "CO"
  },
  "sameAs": [
    "https://www.instagram.com/adricrisrueda/",
    "https://www.facebook.com/adricrisespiritual/",
    "https://www.youtube.com/@adricrisespiritual",
    "https://co.linkedin.com/in/adriana-cristina-rueda"
  ]
}
</script>
