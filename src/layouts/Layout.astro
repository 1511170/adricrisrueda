---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { 
  title = 'AdriCris Rueda | Vida Consciente & Una Voz al Paso del Eclipse'
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AdriCris Rueda - Terapeuta Holística, Autora y Guía Espiritual. Descubre 'Lazos Escritos' y 'Una Voz al paso del Eclipse'." />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tenor+Sans&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    
    <!-- Slot para head adicional -->
    <slot name="head" />
  </head>
  <body class="font-body bg-background-light dark:bg-background-dark text-gray-700 dark:text-gray-200 transition-colors duration-300 antialiased selection:bg-secondary selection:text-white">
    
    <!-- Navigation -->
    <nav class="fixed w-full z-50 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md border-b border-secondary/10 dark:border-gray-800 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-24">
          <!-- Logo -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="flex items-center gap-3">
              <img src="/images/logo-sin-fondo.png" alt="AdriCris Rueda" class="h-16 w-auto" />
            </a>
          </div>
          
          <!-- Desktop Nav -->
          <div class="hidden md:flex space-x-10 items-center">
            <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium tracking-wide text-sm transition-all hover:-translate-y-0.5">INICIO</a>
            <a href="/sobre-mi" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium tracking-wide text-sm transition-all hover:-translate-y-0.5">SOBRE MÍ</a>
            <a href="/libros" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium tracking-wide text-sm transition-all hover:-translate-y-0.5">BIBLIOTECA</a>
            <a href="/libro" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium tracking-wide text-sm transition-all hover:-translate-y-0.5 flex items-center gap-1">
              LIBRO
              <span class="px-2 py-0.5 bg-secondary text-primary text-[10px] font-bold uppercase tracking-wider rounded-full">Nuevo</span>
            </a>
            <a href="/servicios" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium tracking-wide text-sm transition-all hover:-translate-y-0.5">SERVICIOS</a>
            <button class="gold-gradient hover:opacity-90 text-primary px-6 py-2.5 rounded-full font-display font-bold shadow-lg shadow-secondary/20 hover:shadow-secondary/40 transition-all transform hover:-translate-y-0.5 tracking-wide text-sm">
              AGENDAR CONSULTA
            </button>
            <button id="theme-toggle" class="p-2 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" aria-label="Toggle dark mode">
              <span class="material-symbols-outlined text-gray-600 dark:text-gray-300">contrast</span>
            </button>
          </div>
          
          <!-- Mobile Menu Button -->
          <div class="md:hidden flex items-center">
            <button id="theme-toggle-mobile" class="p-2 mr-2 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" aria-label="Toggle dark mode">
              <span class="material-symbols-outlined text-gray-600 dark:text-gray-300">contrast</span>
            </button>
            <button id="mobile-menu-btn" class="text-gray-600 dark:text-gray-300 hover:text-primary p-2" aria-label="Menu">
              <span class="material-symbols-outlined text-3xl">menu</span>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-background-light dark:bg-background-dark border-t border-secondary/10 dark:border-gray-800">
        <div class="px-4 py-4 space-y-3">
          <a href="/" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium">INICIO</a>
          <a href="/sobre-mi" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium">SOBRE MÍ</a>
          <a href="/libros" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium">BIBLIOTECA</a>
          <a href="/libro" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium flex items-center gap-2">
            LIBRO
            <span class="px-2 py-0.5 bg-secondary text-primary text-[10px] font-bold uppercase tracking-wider rounded-full">Nuevo</span>
          </a>
          <a href="/servicios" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-secondary font-medium">SERVICIOS</a>
          <button class="w-full gold-gradient text-primary px-6 py-3 rounded-full font-display font-bold shadow-lg mt-4">
            AGENDAR CONSULTA
          </button>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <slot />

    <!-- Footer -->
    <footer class="bg-surface-dark text-white pt-20 pb-10 border-t border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 mb-16">
          <!-- Brand -->
          <div class="lg:col-span-4">
            <div class="flex items-center gap-3 mb-6">
              <img src="/images/logo-sin-fondo.png" alt="AdriCris Rueda" class="h-12 w-auto" />
            </div>
            <p class="text-gray-400 text-sm font-light leading-relaxed mb-8 max-w-sm">
              Acompañándote en el camino de regreso a ti mismo a través de la terapia holística, la sanación intuitiva y el amor consciente.
            </p>
            <div class="flex space-x-4">
              <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-secondary hover:bg-white/10 transition-all">
                <span class="font-bold text-xs">FB</span>
              </a>
              <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-secondary hover:bg-white/10 transition-all">
                <span class="font-bold text-xs">IG</span>
              </a>
              <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-secondary hover:bg-white/10 transition-all">
                <span class="font-bold text-xs">YT</span>
              </a>
            </div>
          </div>
          
          <!-- Explore -->
          <div class="lg:col-span-2 lg:col-start-6">
            <h4 class="font-display font-bold text-lg mb-6 text-secondary tracking-wide">Explorar</h4>
            <ul class="space-y-4 text-sm text-gray-400 font-light">
              <li><a href="/" class="hover:text-white hover:translate-x-1 inline-block transition-all">Inicio</a></li>
              <li><a href="/sobre-mi" class="hover:text-white hover:translate-x-1 inline-block transition-all">Sobre Mí</a></li>
              <li><a href="#libro" class="hover:text-white hover:translate-x-1 inline-block transition-all">Mis Libros</a></li>
              <li><a href="/servicios" class="hover:text-white hover:translate-x-1 inline-block transition-all">Servicios</a></li>
            </ul>
          </div>
          
          <!-- Contact -->
          <div class="lg:col-span-3">
            <h4 class="font-display font-bold text-lg mb-6 text-secondary tracking-wide">Contacto</h4>
            <ul class="space-y-4 text-sm text-gray-400 font-light">
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-base mt-0.5">mail</span>
                <span class="hover:text-white transition-colors cursor-pointer">adriana@adricrisrueda.com</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-base mt-0.5">location_on</span>
                <span>Bogotá, Colombia</span>
              </li>
            </ul>
          </div>
          
          <!-- Legal -->
          <div class="lg:col-span-2">
            <h4 class="font-display font-bold text-lg mb-6 text-secondary tracking-wide">Legal</h4>
            <ul class="space-y-4 text-sm text-gray-400 font-light">
              <li><a href="#" class="hover:text-white hover:translate-x-1 inline-block transition-all">Política de Privacidad</a></li>
              <li><a href="#" class="hover:text-white hover:translate-x-1 inline-block transition-all">Términos</a></li>
            </ul>
          </div>
        </div>
        
        <!-- Bottom -->
        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500 font-light">
          <p>© {new Date().getFullYear()} AdriCris Rueda. Todos los derechos reservados.</p>
          <div class="mt-4 md:mt-0 flex gap-4">
            <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Site secure</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Floating WhatsApp Button -->
    <a
      href="https://wa.me/573132979675"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:scale-110 animate-pulse"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <!-- Scripts -->
    <script>
      // Dark mode toggle
      const themeToggles = document.querySelectorAll('#theme-toggle, #theme-toggle-mobile');
      themeToggles.forEach(toggle => {
        toggle?.addEventListener('click', () => {
          document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        });
      });
      
      // Check for saved theme preference
      if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
      
      // Close mobile menu when clicking a link
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
